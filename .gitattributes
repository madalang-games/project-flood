# Unity text assets — force LF to prevent Windows autocrlf noise
*.cs            text eol=lf
*.shader        text eol=lf
*.cginc         text eol=lf
*.compute       text eol=lf
*.hlsl          text eol=lf
*.glsl          text eol=lf

# Unity serialized assets
*.prefab        text eol=lf
*.unity         text eol=lf
*.asset         text eol=lf
*.mat           text eol=lf
*.anim          text eol=lf
*.controller    text eol=lf
*.overrideController text eol=lf
*.mask          text eol=lf
*.playable      text eol=lf
*.meta          text eol=lf
*.inputactions  text eol=lf

# Config / data
*.json          text eol=lf
*.xml           text eol=lf
*.yaml          text eol=lf
*.yml           text eol=lf
*.csv           text eol=lf
*.txt           text eol=lf
*.md            text eol=lf
*.gradle        text eol=lf
*.bat           text eol=crlf

# Binary — never diff or merge
*.png           binary
*.jpg           binary
*.jpeg          binary
*.gif           binary
*.bmp           binary
*.tga           binary
*.psd           binary
*.ttf           binary
*.otf           binary
*.wav           binary
*.mp3           binary
*.ogg           binary
*.mp4           binary
*.fbx           binary
*.obj           binary
*.dll           binary
*.so            binary
*.a             binary
*.aab           binary
*.apk           binary
