# Copy to .env.dev and fill values.
# Usage: docker compose --env-file .env.dev -f docker-compose.yml -f docker-compose.dev.yml up -d

COMPOSE_PROJECT_NAME=project-flood
GAME_ENV=dev
ASPNETCORE_ENVIRONMENT=Development

API_BIND_ADDRESS=0.0.0.0
API_PUBLISHED_PORT=20201
API_CONTAINER_PORT=8080

DB_BIND_ADDRESS=127.0.0.1
DB_PUBLISHED_PORT=20206
DB_CONTAINER_PORT=3306
DB_NAME=projectflood_db
DB_USER=root
DB_PASSWORD=change_me
DB_ROOT_PASSWORD=change_me_root

REDIS_CONTAINER_PORT=6379

APP_CLIENT_ID=project-flood-client
APP_ALLOWED_CLIENT_VERSION=1.0.0
APP_REQUIRED_CLIENT_VERSION=1.0.0
APP_ALLOWED_PROTOCOL_VERSION=1

AUTH_USE_MOCK=true
AD_REWARD_VERIFY_MODE=mock
JWT_AUTHORITY=http://platform-auth:8080
JWT_ISSUER=http://platform-auth:8080
JWT_AUDIENCE=platform-games

LOG_LEVEL=Information
RATE_LIMIT_TRANSACTIONAL_PER_MINUTE=30
