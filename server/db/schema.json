{
  "database": "projectflood_db",
  "output": {
    "namespace": "ProjectFlood.Infrastructure.Generated",
    "context": "AppDbContext"
  },
  "tables": [
    {
      "name": "players",
      "comment": "Game-local player record. platform_pid is the 24-char public cross-reference from platform-auth JWT sub.",
      "conflict": "ignore",
      "columns": [
        { "name": "user_id",            "type": "int64",      "pk": true,  "null": false },
        { "name": "platform_pid",       "type": "string(24)", "null": false, "unique": true },
        { "name": "display_name",       "type": "string(64)", "null": false },
        { "name": "avatar_id",          "type": "int32",      "null": false, "default": 1 },
        { "name": "account_created_at", "type": "datetime",   "null": false },
        { "name": "last_login_at",      "type": "datetime",   "null": false }
      ]
    },
    {
      "name": "sessions",
      "conflict": "ignore",
      "columns": [
        { "name": "id",         "type": "int64",      "pk": true,  "auto": true, "null": false },
        { "name": "user_id",    "type": "int64",      "null": false, "fk": "players.user_id" },
        { "name": "session_id", "type": "string(24)", "null": false, "unique": true },
        { "name": "created_at", "type": "datetime",   "null": false },
        { "name": "expires_at", "type": "datetime",   "null": false }
      ]
    },
    {
      "name": "event_logs",
      "comment": "Audit log for all user-modifying API calls.",
      "columns": [
        { "name": "id",             "type": "int64",      "pk": true, "auto": true, "null": false },
        { "name": "user_id",        "type": "int64",      "null": false, "fk": "players.user_id" },
        { "name": "tr_id",          "type": "int32",      "null": false },
        { "name": "correlation_id", "type": "string(36)", "null": false },
        { "name": "params",         "type": "json",       "null": true },
        { "name": "created_at",     "type": "datetime",   "null": false }
      ],
      "indexes": [
        { "name": "idx_event_logs_user_id", "columns": ["user_id"], "unique": false },
        { "name": "idx_event_logs_tr_id", "columns": ["tr_id"], "unique": false },
        { "name": "idx_event_logs_correlation_id", "columns": ["correlation_id"], "unique": false }
      ]
    },
    {
      "name": "user_stamina_state",
      "comment": "Lazy-evaluated life and unlimited stamina state per player.",
      "columns": [
        { "name": "user_id",                           "type": "int64",    "pk": true, "null": false, "fk": "players.user_id" },
        { "name": "current_life",                      "type": "int32",    "null": false },
        { "name": "last_regen_at",                     "type": "datetime", "null": false },
        { "name": "unlimited_until",                   "type": "datetime", "null": true },
        { "name": "last_daily_unlimited_claimed_date", "type": "date",     "null": true },
        { "name": "updated_at",                        "type": "datetime", "null": false }
      ]
    },
    {
      "name": "user_reward_claim_state",
      "comment": "Per-player reward source claim state. Event history is stored in event_logs.",
      "columns": [
        { "name": "user_id",         "type": "int64",      "pk": true, "null": false, "fk": "players.user_id" },
        { "name": "source_id",       "type": "string(64)", "pk": true, "null": false },
        { "name": "period_key",      "type": "string(32)", "pk": true, "null": false },
        { "name": "claim_count",     "type": "int32",      "null": false, "default": 0 },
        { "name": "last_claimed_at", "type": "datetime",   "null": false },
        { "name": "updated_at",      "type": "datetime",   "null": false }
      ],
      "indexes": [
        { "name": "idx_reward_claim_state_user_id", "columns": ["user_id"], "unique": false }
      ]
    },
    {
      "name": "ad_reward_transactions",
      "comment": "Common rewarded-ad transaction table for idempotent verification and grant history.",
      "conflict": "ignore",
      "columns": [
        { "name": "id",             "type": "string(36)",  "pk": true, "null": false },
        { "name": "user_id",        "type": "int64",       "null": false, "fk": "players.user_id" },
        { "name": "placement_id",   "type": "string(64)",  "null": false },
        { "name": "reward_type",    "type": "string(32)",  "null": false },
        { "name": "reward_value",   "type": "int32",       "null": false },
        { "name": "context_type",   "type": "string(32)",  "null": true },
        { "name": "context_id",     "type": "string(128)", "null": true },
        { "name": "provider",       "type": "string(32)",  "null": false },
        { "name": "provider_tx_id", "type": "string(128)", "null": false },
        { "name": "status",         "type": "string(32)",  "null": false },
        { "name": "correlation_id", "type": "string(36)",  "null": false },
        { "name": "created_at",     "type": "datetime",    "null": false },
        { "name": "verified_at",    "type": "datetime",    "null": true },
        { "name": "granted_at",     "type": "datetime",    "null": true }
      ],
      "indexes": [
        { "name": "uq_ad_reward_provider_tx", "columns": ["provider", "provider_tx_id"], "unique": true },
        { "name": "idx_ad_reward_user_id", "columns": ["user_id"], "unique": false },
        { "name": "idx_ad_reward_context", "columns": ["context_type", "context_id"], "unique": false },
        { "name": "idx_ad_reward_correlation_id", "columns": ["correlation_id"], "unique": false }
      ]
    }
  ]
}
